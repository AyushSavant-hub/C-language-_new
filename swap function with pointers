#include <stdio.h>
void swap(int *a,int *b);
int main() {
    int x,y;
    printf("enter two integers:\n");
    printf("x=");
    scanf("%d",&x);
    printf("y=");
    scanf("%d",&y);
    printf("before swaping x=%d and y=%d\n",x,y);
    swap((&x),(&y));
    printf("after swaping x=%d and y=%d",x,y);
    return 0;}
void swap(int *a,int *b){
    int temp;
    temp=*a;
    *a=*b;
    *b=temp;
}
